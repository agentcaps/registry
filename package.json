{
  "name": "@agentcaps/registry",
  "version": "0.2.1",
  "description": "Enterprise-grade ARD registry for approved agent capabilities.",
  "type": "module",
  "bin": {
    "agentcaps-registry": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "smoke": "pnpm build && node scripts/smoke.mjs",
    "prepack": "pnpm build",
    "pack:check": "pnpm pack --dry-run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.35",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentcaps/registry.git"
  },
  "bugs": {
    "url": "https://github.com/agentcaps/registry/issues"
  },
  "homepage": "https://github.com/agentcaps/registry#readme",
  "packageManager": "pnpm@10.30.2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agent",
    "ai-agent",
    "agent-capabilities",
    "ard",
    "ai-catalog",
    "skill-md",
    "registry",
    "mcp",
    "a2a",
    "governance"
  ]
}
